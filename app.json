{
  "expo": {
    "scheme": "igem-alginate",
    "name": "igem-alginate-film-mobile",
    "slug": "alginate-film-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-1024.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo-1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hhhk.igemalginatefilmmobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "This app requires access to your location to map and log heavy metal contamination data points accurately."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-1024.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.hhhk.igemalginatefilmmobile",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDkcCX-ee7h42FN0ld5mbCFBAUXdh2nkJA"
        }
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "652c2a0a-b4f9-4b08-8f21-b89ce41d6fad"
      }
    },
    "owner": "igemwiki"
  }
}
